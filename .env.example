# ========================================
# Application Configuration
# ========================================
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# ========================================
# Database Configuration (MySQL + Prisma)
# ========================================
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/nestjs_db"

# ========================================
# JWT Configuration
# ========================================
# Access token secret — use a long, random string in production
JWT_ACCESS_SECRET=your_super_secret_access_token_key_change_in_production
JWT_ACCESS_EXPIRES_IN=15m

# Refresh token secret — use a different long, random string in production
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key_change_in_production
JWT_REFRESH_EXPIRES_IN=7d

# ========================================
# Bcrypt Configuration
# ========================================
BCRYPT_SALT_ROUNDS=12

# ========================================
# Rate Limiting
# ========================================
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ========================================
# CORS Configuration
# ========================================
CORS_ORIGIN=http://localhost:3000
